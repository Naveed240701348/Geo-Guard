{
  "name": "geoguard",
  "version": "1.0.0",
  "description": "GIS-Based Government Land Protection & Encroachment Monitoring System for Tamil Nadu",
  "main": "server/index.js",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "cd server && npm run dev",
    "client": "cd client && npm run dev",
    "build": "cd client && npm run build",
    "start": "cd server && npm start",
    "install-all": "npm install && cd server && npm install && cd ../client && npm install",
    "deploy": "./deploy.sh"
  },
  "keywords": [
    "gis",
    "land-management",
    "government",
    "tamil-nadu",
    "encroachment",
    "mapping",
    "react",
    "nodejs",
    "firebase",
    "leaflet"
  ],
  "author": "GeoGuard Team",
  "license": "MIT",
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0"
  },
  "dependencies": {
    "express": "^5.2.1"
  }
}
